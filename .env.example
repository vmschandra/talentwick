# Firebase (required for core app)
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# Firebase Admin (required for protected API routes — admin credit management etc.)
# Get from Firebase console → Project settings → Service accounts → Generate new private key
FIREBASE_ADMIN_PROJECT_ID=
FIREBASE_ADMIN_CLIENT_EMAIL=
FIREBASE_ADMIN_PRIVATE_KEY=

# Payment Provider: "cashfree" | "stripe" | "razorpay" | "paypal" | "manual" (default: "manual")
NEXT_PUBLIC_PAYMENT_PROVIDER=

# Cashfree — get keys from https://merchant.cashfree.com → Developers → API keys
# CASHFREE_APP_ID      → App ID (shown in the API keys section)
# CASHFREE_SECRET_KEY  → Secret Key (shown in the API keys section)
# CASHFREE_ENV         → "sandbox" for testing, "production" for live
# NEXT_PUBLIC_CASHFREE_ENV → same value as CASHFREE_ENV (needed by the browser SDK)
#
# Webhook endpoint to register in Cashfree dashboard:
#   https://yourdomain.com/api/payments/webhook
#   Events: PAYMENT_SUCCESS_WEBHOOK, PAYMENT_FAILED_WEBHOOK
CASHFREE_APP_ID=
CASHFREE_SECRET_KEY=
CASHFREE_ENV=sandbox
NEXT_PUBLIC_CASHFREE_ENV=sandbox

# Stripe — get keys from https://dashboard.stripe.com/apikeys
# STRIPE_SECRET_KEY       → Developers → API keys → Secret key (sk_live_... or sk_test_...)
# STRIPE_WEBHOOK_SECRET   → Developers → Webhooks → your endpoint → Signing secret (whsec_...)
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY → Developers → API keys → Publishable key (pk_live_... or pk_test_...)
#
# Webhook endpoint to register in Stripe dashboard:
#   https://yourdomain.com/api/payments/webhook
#   Events to listen for: checkout.session.completed, checkout.session.expired
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# If Razorpay:
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=
NEXT_PUBLIC_RAZORPAY_KEY_ID=

# If PayPal:
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
PAYPAL_WEBHOOK_ID=
NEXT_PUBLIC_PAYPAL_CLIENT_ID=

# Optional
NEXT_PUBLIC_APP_URL=
RESEND_API_KEY=
SENDGRID_API_KEY=
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASS=
