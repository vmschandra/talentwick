rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helpers ──────────────────────────────────────────────────────────
    function isSignedIn() {
      return request.auth != null;
    }

    // get() calls are cached within a single rule evaluation, so repeated
    // calls to userRole() in one expression cost at most one extra read.
    function userRole() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
    }

    function isAdmin() {
      return isSignedIn() && userRole() == "admin";
    }

    function isRecruiter() {
      return isSignedIn() && userRole() == "recruiter";
    }

    // ── Users ─────────────────────────────────────────────────────────────
    match /users/{userId} {
      allow read: if isSignedIn();
      // Own doc or admin
      allow write: if isSignedIn() && (request.auth.uid == userId || isAdmin());
    }

    // ── Candidate Profiles ────────────────────────────────────────────────
    match /candidateProfiles/{userId} {
      // Own profile, any recruiter, or admin
      allow read: if isSignedIn() && (
        request.auth.uid == userId || isRecruiter() || isAdmin()
      );
      allow write: if isSignedIn() && request.auth.uid == userId;
    }

    // ── Recruiter Profiles ────────────────────────────────────────────────
    match /recruiterProfiles/{userId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn() && (request.auth.uid == userId || isAdmin());
    }

    // ── Jobs ──────────────────────────────────────────────────────────────
    match /jobs/{jobId} {
      // Active jobs are public; draft/paused/closed only visible to their owner or admin
      allow read: if resource.data.status == "active" ||
        (isSignedIn() && (request.auth.uid == resource.data.recruiterId || isAdmin()));
      allow create: if isRecruiter();
      allow update: if isSignedIn() &&
        (request.auth.uid == resource.data.recruiterId || isAdmin());
      allow delete: if isSignedIn() &&
        (request.auth.uid == resource.data.recruiterId || isAdmin());
    }

    // ── Applications ──────────────────────────────────────────────────────
    match /applications/{appId} {
      // Only candidates may apply
      allow create: if isSignedIn() && userRole() == "candidate" &&
        request.resource.data.candidateId == request.auth.uid;

      // Owner candidate, owning recruiter, or admin may read
      allow read: if isSignedIn() && (
        request.auth.uid == resource.data.candidateId ||
        request.auth.uid == resource.data.recruiterId ||
        isAdmin()
      );

      // Recruiter updates status; candidate can only withdraw their own application
      allow update: if isSignedIn() && (
        request.auth.uid == resource.data.recruiterId ||
        (
          request.auth.uid == resource.data.candidateId &&
          request.resource.data.status == "withdrawn" &&
          request.resource.data.diff(resource.data).affectedKeys()
            .hasOnly(["status", "statusHistory", "updatedAt"])
        ) ||
        isAdmin()
      );

      // Recruiter (job owner) or admin may delete — needed for job cleanup
      allow delete: if isSignedIn() && (
        request.auth.uid == resource.data.recruiterId || isAdmin()
      );
    }

    // ── Transactions ──────────────────────────────────────────────────────
    match /transactions/{txId} {
      // Only the owning recruiter or admin may read; writes are server-side only
      allow read: if isSignedIn() && (
        request.auth.uid == resource.data.recruiterId || isAdmin()
      );
    }

    // ── Notifications ─────────────────────────────────────────────────────
    match /notifications/{notifId} {
      allow read, update: if isSignedIn() &&
        request.auth.uid == resource.data.userId;
    }

    // ── Conversations ─────────────────────────────────────────────────────
    match /conversations/{convId} {
      // Participants can read and update (lastMessage, unreadCount, etc.)
      allow read, update: if isSignedIn() && (
        request.auth.uid == resource.data.candidateId ||
        request.auth.uid == resource.data.recruiterId ||
        isAdmin()
      );
      // Only a recruiter can start a new conversation (as the recruiter participant)
      allow create: if isSignedIn() && (
        request.auth.uid == request.resource.data.recruiterId ||
        request.auth.uid == request.resource.data.candidateId
      );

      // Messages subcollection — participants only
      match /messages/{msgId} {
        allow read, create: if isSignedIn() && (
          request.auth.uid == get(/databases/$(database)/documents/conversations/$(convId)).data.candidateId ||
          request.auth.uid == get(/databases/$(database)/documents/conversations/$(convId)).data.recruiterId ||
          isAdmin()
        );
      }
    }
  }
}
