rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    // Resumes — any signed-in user may read; only the owner may write
    match /resumes/{uid}/{filename} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == uid;
    }

    // Avatars — any signed-in user may read; only the owner may write
    match /avatars/{uid}/{filename} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == uid;
    }

    // Company logos — any signed-in user may read; only the owner may write
    match /logos/{uid}/{filename} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == uid;
    }

    // Deny everything else
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
